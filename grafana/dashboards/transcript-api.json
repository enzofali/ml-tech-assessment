    {
      "type": "timeseries",
      "title": "HTTP Error Rate (4xx / 5xx)",
      "id": 17,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 44 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
